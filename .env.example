# =============================================================================
# Forge — gabarit de configuration par variables d'environnement.
# Copier vers `.env` (gitignored) et renseigner. Usage AUTORISÉ uniquement.
#
#   cp .env.example .env      # puis remplir les SECRETS ci-dessous
#
# Légende des marqueurs inline :
#   [SECRET]   = ne JAMAIS committer / logguer ; garder le fichier .env en 0600.
#   [PURPLE]   = active la boucle purple (couverture de détection) ; la SOURCE est un plugin configurable
#                (Plume n'est qu'un préréglage parmi d'autres) — cf. docs/DETECTION.md & docs/PURPLE_PREREQS.md.
#   [OPERATOR] = provisionne / ouvre le rôle OPÉRATEUR (C2) ; vide = C2 FERMÉ (fail-closed).
#
# Sûreté : les défauts ci-dessous laissent Forge INERTE et en loopback. Rien n'est armé.
# Les lignes commentées (#VAR=…) sont OFF par défaut ; décommenter en connaissance de cause.
# En Docker, le bloc `environment:` du compose surcharge ces valeurs pour les chemins /data/*.
# =============================================================================

# --- Console (binaire Rust) : bind, chemins d'état, session --------------------
FORGE_CONSOLE_ADDR=127.0.0.1:7100                 # bind API/UI ; JAMAIS 0.0.0.0 sans reverse-proxy + auth + host-allowlist
FORGE_CONSOLE_DB=/var/lib/forge/db/forge.db          # store SQLite (findings/runrecords)
FORGE_CONSOLE_LEDGER=/var/lib/forge/ledger/engagement.jsonl  # ledger d'engagement append-time
FORGE_CONSOLE_SCOPE=/var/lib/forge/scope/scope.json          # scope/ROE ACTIF (in_scope vide = INERTE)
FORGE_CONSOLE_WEB=/opt/forge/console/web                     # assets UI opérateur
FORGE_CONSOLE_USER=forge                          # identifiant du rôle viewer (Basic auth)
FORGE_CONSOLE_SESSION_TTL=3600                    # durée de vie d'une session (s) ; sessions courtes
#FORGE_CONSOLE_HOST=console.exemple.test          # allowlist Host anti-DNS-rebinding (CSV) si exposé via proxy
#FORGE_CONSOLE_LEDGER_PUBKEY=                      # clé publique Ed25519 (hex 64) pour `ledger verify` côté console (publique, non secrète)

# --- Console : secrets d'authentification / RBAC ------------------------------
# Vides = mode dev localhost-ouvert pour le viewer, token d'ingestion généré au boot,
# rôle opérateur NON provisionné (C2 fermé). Renseigner pour un déploiement durci.
#FORGE_CONSOLE_TOKEN=                              # [SECRET] bearer d'ingestion (CSPRNG : `openssl rand -hex 16`) ; sinon généré au boot
#FORGE_CONSOLE_PASS_HASH=                          # [SECRET] hash argon2id du rôle viewer (`forge hashpw <pw>`)
#FORGE_CONSOLE_OPERATOR_HASH=                      # [SECRET][OPERATOR] hash argon2id du rôle opérateur C2 (`forge hashpw-operator <pw>`) ; vide = C2 fermé

# --- Client Python (campaign / demo_ingest / doctor) --------------------------
FORGE_CONSOLE_URL=http://127.0.0.1:7100           # cible d'ingestion POST /api/ingest (doit matcher FORGE_CONSOLE_ADDR)

# --- Moteur Python : spawn & timeouts -----------------------------------------
FORGE_PKG_DIR=/opt/forge                          # racine du package python `forge` spawné par la console
FORGE_PYTHON=python3                              # interpréteur utilisé pour spawner `python3 -m forge.cli`
FORGE_RUN_TIMEOUT=900                             # budget max (s) d'un run de module
#FORGE_LEDGER_KEY=                                # [SECRET] matériel de clé de signature du ledger ; vide = clé locale auto-générée (<base>.ed25519, 0600)

# --- ENTERPRISE (E3) : signeur de ledger PLUGGABLE (clé privée OFF-HOST : KMS/HSM/exec) --------
# Défaut communauté = LocalFileSigner (clé <base>.ed25519 sur disque) — inchangé. Le seam distant est
# GATÉ par FORGE_ENTERPRISE_COMPLIANCE=1 ; verify reste identique (clé publique seule). Fail-closed :
# signeur injoignable/mal-configuré => erreur claire, JAMAIS de repli local ni d'entrée non signée.
#FORGE_LEDGER_SIGNER=local                        # local | kms | hsm | http | remote | exec (défaut: local)
#FORGE_LEDGER_SIGNER_PUBKEY=                      # clé publique Ed25519 brute (hex 64) du signeur distant — REQUISE pour vérifier (publique, non secrète)
#FORGE_LEDGER_SIGNER_ENDPOINT=                    # [SECRET] endpoint http(s) KMS/HSM (modes kms|hsm|http|remote)
#FORGE_LEDGER_SIGNER_CREDENTIAL=                  # [SECRET] jeton Bearer pour l'endpoint (jamais loggé/ledgeré/redacted)
#FORGE_LEDGER_SIGNER_ARGV=                        # [SECRET] mode exec : tableau JSON no-shell, ex: ["/opt/forge-signer","--slot","0"] (argv fixe, pas de shell)
#FORGE_LEDGER_SIGNER_TIMEOUT=10                   # délai (s) d'appel au signeur distant

# --- Couche accès/évasion (browser-automation, optionnelle) -------------------
FORGE_BROWSER_URL=http://browser-automation:8080  # service Camoufox+Xvfb ; injoignable = connecteur évasion inerte

# --- Boucle purple : SOURCE DE DÉTECTION (plugin configurable, infra-agnostique) ----
# La source BLUE (SIEM/IDS/pare-feu) se configure de préférence dans l'UI (wizard 1er déploiement ou
# Administration -> Source de détection ; stockée dans settings.detection_source, secret write-only).
# Plume n'est qu'UN préréglage (kind=plume) : CrowdSec, FortiGate, pfSense/OPNsense, Elastic/OpenSearch,
# fichier JSONL, commande… se câblent SANS code. Modèle + préréglages : docs/DETECTION.md.
# Les 2 variables ci-dessous sont le REPLI RÉTRO-COMPAT du préréglage Plume (utilisées seulement si
# settings.detection_source est absent). Vides = boucle purple OFF (/api/detection/coverage, alias
# /api/purple/coverage, répond en fail-open lisible : source_reachable:false, aucune métrique inventée).
#PLUME_URL=http://plume-internal:PORT             # [PURPLE] préréglage kind=plume ; http:// interne uniquement (pas de TLS côté console)
#PLUME_TOKEN=BASE64_USER_COLON_PASS               # [SECRET][PURPLE] Basic auth = base64("user:pass")

# --- Connecteur msf.module (msfrpcd, optionnel) -------------------------------
# Vide/injoignable = connecteur inerte à fire-time (aucune capacité offensive embarquée).
MSF_RPC_HOST=127.0.0.1                            # hôte msfrpcd
MSF_RPC_PORT=55553                                # port RPC msfrpcd
MSF_RPC_USER=msf                                  # utilisateur RPC
MSF_RPC_SSL=true                                  # TLS vers msfrpcd (msfrpcd sert du TLS par défaut)
#MSF_RPC_PASS=                                    # [SECRET] mot de passe RPC (`msfrpcd -P <pass>`)
#MSF_RPC_TOKEN=                                   # [SECRET] token RPC permanent (optionnel, alternative au user/pass)

# --- Connecteur burp.scan (REST API Burp Suite Pro/Enterprise, optionnel) -----
# Vide/injoignable = connecteur inerte à fire-time.
BURP_API_URL=http://127.0.0.1:1337                # base REST API Burp
#BURP_API_KEY=                                    # [SECRET] clé API Burp (souvent intégrée à l'URL : http://127.0.0.1:1337/<key>)

# --- Runtime python (généralement laissé aux défauts de l'image/service) ------
#PYTHONPATH=/opt/forge                            # résolution du package `forge` (fixé par l'image Docker / systemd)
#PYTHONUNBUFFERED=1                               # logs non bufferisés (fixé par l'image Docker)
